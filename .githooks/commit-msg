#!/bin/sh

# Enforce conventional commit messages
# Format: type(optional scope): description
# Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build

MSG_FILE="$1"
MSG=$(head -1 "$MSG_FILE")

PATTERN="^(feat|fix|docs|style|refactor|test|chore|ci|perf|build)(\(.+\))?: .{1,72}$"

if ! echo "$MSG" | grep -qE "$PATTERN"; then
    echo "error: Invalid commit message format."
    echo ""
    echo "Expected: type(scope): description"
    echo ""
    echo "Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build"
    echo "Max length: 72 characters"
    echo ""
    echo "Examples:"
    echo "  feat: add notification sound picker"
    echo "  fix(notifications): correct badge count"
    echo "  docs: update installation guide"
    echo ""
    echo "Your message: $MSG"
    exit 1
fi
